{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gitcron.dev/schemas/task.schema.json",
  "title": "gitcron task",
  "type": "object",
  "required": ["id", "title", "state", "created_at", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^TASK-\\d{3,}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": { "type": "string" },
    "state": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "assignee": { "type": "string" },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state", "at", "by"],
        "properties": {
          "state": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "by": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
